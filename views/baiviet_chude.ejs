<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Tùng" />
	<title><%= title %> - Trang tin điện tử</title>
	<link href="/css/app.css" rel="stylesheet" />
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-md navbar-light bg-white absolute-top">
			<div class="container">
				<button class="navbar-toggler order-2 order-md-1" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse order-3 order-md-2">
					<ul class="navbar-nav me-auto">
						<li class="nav-item dropdown active">
							<a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Chuyên mục</a>
							<div class="dropdown-menu">
								<% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(cd => { %>
									<a class="dropdown-item" href="/baiviet/chude/<%= cd._id %>"><%= cd.TenChuDe %></a>
								<% }); } %>
							</div>
						</li>
					</ul>
				</div>
				<a class="navbar-brand mx-auto" href="/">iNews</a>
				<div class="collapse navbar-collapse">
					<ul class="navbar-nav ms-auto">
						<% if(typeof session === "undefined" || !session.MaNguoiDung) { %>
							<li class="nav-item"><a class="nav-link" href="/dangky">Đăng ký</a></li>
							<li class="nav-item"><a class="nav-link" href="/dangnhap">Đăng nhập</a></li>
						<% } else { %>
							<li class="nav-item"><a class="nav-link" href="/admin">Quản lý</a></li>
							<li class="nav-item"><a class="nav-link" href="/dangxuat">Đăng xuất</a></li>
						<% } %>
					</ul>
					<form action="/timkiem" method="post">
						<input name="tukhoa" class="form-control" type="text" placeholder="Tìm kiếm..." />
					</form>
				</div>
			</div>
		</nav>
	</header>

	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-9">
                    <div class="text-center">
                        <span class="text-muted">Chuyên mục:</span>
                        <h3><%= (typeof chude !== "undefined") ? chude.TenChuDe : 'N/A' %></h3>
                        <hr />
                    </div>

                    <div class="row">
						<% if(typeof baiviet !== "undefined") { %>
							<%
								var chunkSize = 4;
								for(var i = 0; i < baiviet.length; i += chunkSize) {
									var chunk = baiviet.slice(i, i + chunkSize);
							%>
								<div class="col-12">
									<% chunk.forEach(bv => { %>
										<article class="card mb-4">
											<header class="card-header">
												<div>
													<time class="timeago" datetime="<%= bv.NgayDang %>"></time>
													thuộc <a href="/baiviet/chude/<%= bv.ChuDe._id %>"><%= bv.ChuDe.TenChuDe %></a>
												</div>
												<a href="/baiviet/chitiet/<%= bv._id %>">
													<h4><%= bv.TieuDe %></h4>
												</a>
											</header>

											<a href="/baiviet/chitiet/<%= bv._id %>">
												<img class="card-img" src="<%- firstImage(bv.NoiDung) %>" />
											</a>

											<div class="card-body">
												<p><%= bv.TomTat %></p>
											</div>
										</article>
									<% }); %>
								</div>
							<% } %>
						<% } else { %>
							<div class="alert alert-primary">
								Không có bài viết nào
							</div>
						<% } %>
                    </div>
                </div>

				<div class="col-md-3">
					<div class="card mb-4">
						<div class="card-body">
							<h4>Thẻ</h4>
							<% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(cd => { %>
								<a class="btn btn-light btn-sm mb-1" href="/baiviet/chude/<%= cd._id %>"><%= cd.TenChuDe %></a>
							<% }); } %>
						</div>
					</div>
				</div>

			</div>
		</div>
	</main>

	<div class="site-instagram">
		<div class="row g-0">
			<div class="col-3"><img class="img-fluid" src="/images/instagram/1.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/2.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/3.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/4.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/5.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/6.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/7.jpg" /></div>
			<div class="col-3"><img class="img-fluid" src="/images/instagram/8.jpg" /></div>
		</div>
	</div>

	<script src="/js/app.js"></script>
</body>
</html>